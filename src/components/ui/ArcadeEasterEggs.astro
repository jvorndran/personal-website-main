---
// Toast host + client script for Konami / phrase Easter eggs and Arcade console banner.
---

<div
  id="arcade-toast"
  role="status"
  aria-live="polite"
  aria-atomic="true"
  hidden
  class="pointer-events-none fixed bottom-24 left-1/2 z-[200] max-w-[min(90vw,20rem)] -translate-x-1/2 border border-border bg-surface/95 px-4 py-2.5 text-center text-[0.65rem] uppercase tracking-[0.2em] text-text shadow-lg backdrop-blur-md"
>
</div>

<script>
  import { initArcadeEasterEggs } from '../../scripts/arcade-easter-eggs';

  function boot() {
    initArcadeEasterEggs();
  }

  document.addEventListener('astro:page-load', boot);
  boot();
</script>
