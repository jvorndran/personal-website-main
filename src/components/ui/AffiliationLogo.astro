---
interface Props {
  src: string;
  alt: string;
  size?: 'wide' | 'compact';
  class?: string;
}

const { src, alt, size = 'wide', class: className = '' } = Astro.props;
const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const assetPath = (path: string) => `${basePath}${path.replace(/^\//, '')}`;
const resolvedSrc = src.startsWith('http') ? src : assetPath(src);
const sizeClass = size === 'compact' ? 'h-16 w-28 px-2.5 py-2' : 'h-16 w-36 px-3 py-2.5';
---

<span
  class={`flex shrink-0 items-center justify-center rounded-lg border border-[var(--section-accent)]/20 bg-[var(--logo-frame-bg)] transition-colors group-hover:border-[var(--section-accent)]/40 ${sizeClass} ${className}`}
>
  <img
    src={resolvedSrc}
    alt={alt}
    class="max-h-full max-w-full object-contain"
    loading="eager"
    decoding="async"
  />
</span>
